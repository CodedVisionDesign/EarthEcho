generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Auth.js (NextAuth) Required Models
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?   @db.Text
  customImage   String?   @db.Text
  password      String?

  // Profile fields
  displayName String?
  bio         String?  @db.Text
  isPublic    Boolean  @default(true)
  dateOfBirth DateTime?

  // Role-based access control
  role      String  @default("user") // "user", "admin", "superadmin", "developer"

  // Ban management
  banned    Boolean   @default(false)
  banReason String?   @db.Text
  bannedAt  DateTime?
  bannedBy  String?   // userId of the admin who banned

  // Password reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Onboarding
  onboardingCompleted Boolean @default(false)
  tourCompleted       Boolean @default(false)

  // Gamification
  totalPoints  Int       @default(0)
  streakDays   Int       @default(0)
  lastActiveAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts              Account[]
  sessions              Session[]
  activities            Activity[]
  userBadges            UserBadge[]
  challengeParticipants ChallengeParticipant[]
  pointTransactions     PointTransaction[]
  threads               Thread[]
  replies               Reply[]
  reactions             Reaction[]
  guideComments         GuideComment[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  notificationPreference NotificationPreference?
  pushSubscriptions     PushSubscription[]
  webauthnCredentials   WebAuthnCredential[]
  cookieConsent         CookieConsent?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @db.VarChar(512)
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==========================================
// Activity Tracking
// ==========================================

model Activity {
  id       String @id @default(cuid())
  userId   String
  category String // WATER, CARBON, PLASTIC, RECYCLING, TRANSPORT, FASHION
  type     String // e.g., "reusable_bottle", "bus_journey", "ev_commute", "cycling"
  value    Float // Raw value in base units (litres, kg CO2, items, km)
  unit     String // Base unit: "litres", "kg_co2", "items", "kg", "km"
  note     String? @db.Text
  date     DateTime @default(now())

  // Transport-specific fields
  transportMode String? // petrol_car, diesel_car, hybrid, ev, bus, train, plane, cycling, walking, e_scooter
  distanceKm    Float? // Distance in km (for transport activities)
  co2Saved      Float? // kg CO2 saved vs driving a petrol car

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, category])
  @@index([userId, date])
  @@index([date, category])
  @@map("activities")
}

// ==========================================
// Transport Reference Data
// ==========================================

model TransportMode {
  id            String @id @default(cuid())
  slug          String @unique
  name          String
  co2PerKm      Float
  icon          String
  category      String // "car", "public", "active", "flight"
  isZeroEmission Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("transport_modes")
}

// ==========================================
// User Commute (saved regular journeys)
// ==========================================

model SavedCommute {
  id          String @id @default(cuid())
  userId      String
  name        String
  distanceKm  Float
  isReturn    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("saved_commutes")
}

// ==========================================
// Gamification
// ==========================================

model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String @db.Text
  icon        String
  category    String // "starter", "streak", "impact", "community", "challenge", "transport"
  criteria    String @db.Text // JSON describing unlock criteria
  rarity      String @default("common") // common, uncommon, rare, epic, legendary

  userBadges UserBadge[]

  createdAt DateTime @default(now())

  @@map("badges")
}

model UserBadge {
  id      String @id @default(cuid())
  userId  String
  badgeId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Challenge {
  id          String @id @default(cuid())
  title       String
  description String @db.Text
  category    String // WATER, CARBON, PLASTIC, RECYCLING, TRANSPORT, FASHION
  targetValue Float
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean @default(false)

  // Workflow status: DRAFT | PENDING_REVIEW | APPROVED | ACTIVE | COMPLETED | ARCHIVED
  status          String    @default("DRAFT")
  createdById     String?
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?   @db.Text

  participants ChallengeParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([status])
  @@map("challenges")
}

model ChallengeParticipant {
  id          String @id @default(cuid())
  userId      String
  challengeId String
  progress    Float  @default(0)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, challengeId])
  @@map("challenge_participants")
}

model PointTransaction {
  id     String @id @default(cuid())
  userId String
  points Int
  reason String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("point_transactions")
}

// ==========================================
// Forum
// ==========================================

model Thread {
  id       String  @id @default(cuid())
  userId   String
  title    String
  content  String  @db.Text
  category String // "tips", "challenges", "wins", "questions"
  isPinned Boolean @default(false)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies Reply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("threads")
}

model Reply {
  id            String  @id @default(cuid())
  threadId      String
  userId        String
  content       String  @db.Text
  parentReplyId String?

  thread       Thread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentReply  Reply?     @relation("ReplyToReply", fields: [parentReplyId], references: [id], onDelete: Cascade)
  childReplies Reply[]    @relation("ReplyToReply")
  reactions    Reaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threadId])
  @@index([parentReplyId])
  @@map("replies")
}

model Reaction {
  id      String @id @default(cuid())
  replyId String
  userId  String
  type    String @default("cheer") // "cheer", "helpful", "inspiring"

  reply Reply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([replyId, userId, type])
  @@map("reactions")
}

// ==========================================
// Resources
// ==========================================

model Resource {
  id          String  @id @default(cuid())
  name        String  @unique
  description String  @db.Text
  url         String  @db.Text
  category    String // "energy", "water", "recycling", "transport", "shopping", "food_waste", "recycling_tools", "wildlife", "ethical_shopping", "impact_investing", "vegan", "reduce_waste"
  image       String? @db.Text // optional logo/image URL
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("resources")
}

// ==========================================
// Guides
// ==========================================

model Guide {
  id              String  @id @default(cuid())
  slug            String  @unique
  title           String
  subtitle        String  @db.Text
  icon            String  @default("faBookOpen") // FontAwesome icon name
  category        String // "energy", "water", "waste", "food", etc.
  categoryLabel   String
  readTimeMinutes Int     @default(5)
  introduction    String  @db.Text
  sections        String  @db.LongText // JSON array of GuideSection
  quickTips       String  @db.LongText // JSON array of strings
  sources         String  @db.LongText // JSON array of { name, url }
  lastUpdated     String
  isPublished     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isPublished])
  @@map("guides")
}

// ==========================================
// Guide Comments
// ==========================================

model GuideComment {
  id        String @id @default(cuid())
  guideSlug String
  userId    String
  content   String @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guideSlug, createdAt])
  @@map("guide_comments")
}

// ==========================================
// Forum Moderation Words
// ==========================================

model ModerationWord {
  id   String @id @default(cuid())
  word String @unique
  type String // "flag" (alert admin) or "ban" (auto-block post)

  createdAt DateTime @default(now())

  @@index([type])
  @@map("moderation_words")
}

// ==========================================
// Audit Logging
// ==========================================

model AuditLog {
  id        String @id @default(cuid())
  adminId   String
  action    String // "ban_user", "unban_user", "delete_thread", "delete_reply", "promote_admin", "demote_admin"
  targetId  String? // ID of the affected entity
  targetType String? // "user", "thread", "reply"
  details   String? @db.Text // JSON with extra context
  ipAddress String?

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ==========================================
// Notifications
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "reply", "thread_follow", "reaction", "badge", "challenge", "system"
  title     String
  body      String   @db.Text
  href      String?
  read      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id     String  @id @default(cuid())
  userId String  @unique
  inApp  Boolean @default(true)
  email  Boolean @default(true)
  push   Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  endpoint String @db.Text
  p256dh   String @db.Text
  auth     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, endpoint(length: 500)])
  @@map("push_subscriptions")
}

// ==========================================
// Password Reset Tokens
// ==========================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @db.VarChar(512)
  expires   DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

// ==========================================
// App Settings (key-value store)
// ==========================================

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt

  @@map("app_settings")
}

// ==========================================
// Challenge Templates (auto-generation)
// ==========================================

model ChallengeTemplate {
  id           String  @id @default(cuid())
  category     String  @unique
  titlePattern String
  description  String  @db.Text
  targetValue  Float
  isEnabled    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("challenge_templates")
}

// ==========================================
// WebAuthn Credentials (Passkeys)
// ==========================================

model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  credentialId String   @unique @db.VarChar(512)
  publicKey    Bytes    @db.Blob
  counter      BigInt   @default(0)
  transports   String?  @db.VarChar(255)
  deviceName   String?  @db.VarChar(100)
  backedUp     Boolean  @default(false)
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("webauthn_credentials")
}

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  challenge String   @db.VarChar(512)
  userId    String?
  type      String   @db.VarChar(20)
  expiresAt DateTime

  @@index([challenge])
  @@index([expiresAt])
  @@map("webauthn_challenges")
}

// ==========================================
// Cookie Consent Audit Trail (GDPR)
// ==========================================

model CookieConsent {
  id        String   @id @default(cuid())
  userId    String   @unique
  analytics Boolean  @default(false)
  givenAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cookie_consents")
}

// ==========================================
// Flagged Activities (anomaly detection)
// ==========================================

model FlaggedActivity {
  id         String    @id @default(cuid())
  activityId String
  userId     String
  reason     String    @db.Text
  category   String
  value      Float
  status     String    @default("PENDING") // PENDING, REVIEWED, DISMISSED
  reviewedBy String?
  reviewedAt DateTime?
  reviewNote String?   @db.Text

  createdAt  DateTime  @default(now())

  @@index([status])
  @@index([userId])
  @@map("flagged_activities")
}
