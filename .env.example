# Database
# Local dev (SQLite - zero setup):
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL on VPS):
# DATABASE_URL="postgresql://user:password@localhost:5432/carbon_footprint"

# Auth.js - generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth (https://developers.facebook.com)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Redis (optional, for caching in production)
# REDIS_URL="redis://localhost:6379"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
